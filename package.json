{
  "name": "vybe",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:demo": "cross-env NEXT_PUBLIC_VYBE_DATA_MODE=demo next dev",
    "build": "next build",
    "build:demo": "cross-env NEXT_PUBLIC_VYBE_DATA_MODE=demo next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:security": "node tests/sql-security.test.mjs",
    "test:cloud": "node tests/integration/supabase-phase5.mjs",
    "test:e2e": "npm run build:demo && node tests/run-browser-suites.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test:security && npm run build",
    "test:cloud:friends": "node tests/integration/supabase-two-user.mjs",
    "test:cloud:phase3": "node tests/integration/supabase-three-user.mjs",
    "test:cloud:video-pairing": "node tests/integration/supabase-video-pairing.mjs"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.23",
    "@livekit/protocol": "^1.50.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.6",
    "framer-motion": "^12.42.2",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
